// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS DE DOMÍNIO
// ==========================================

enum Role {
  CLIENTE
  PROPRIETARIO
}

enum PropertyType {
  CASA
  APARTAMENTO
}

enum TransactionType {
  VENDA
  ALUGUEL
}

enum PropertyStatus {
  RASCUNHO
  PUBLICADO
  PAUSADO
  VENDIDO
  ALUGADO
  INATIVO
}

// ==========================================
// MODELOS
// ==========================================

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String
  phone        String?
  role         Role

  // Relacionamentos - Cliente
  searchHistory SearchHistory[]

  // Relacionamentos - Proprietário
  ownedProperties Property[] @relation("OwnerProperties")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([email])
}

model SearchHistory {
  id    String @id @default(uuid())
  query String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  price       Decimal  @db.Decimal(12, 2)
  address     String
  photos      String[]

  propertyType    PropertyType
  transactionType TransactionType
  status          PropertyStatus  @default(RASCUNHO)

  // Características Estruturais
  bedrooms  Int
  bathrooms Int
  area      Decimal  @db.Decimal(10, 2)
  garages   Int
  amenities String[]

  // Métricas de Performance
  viewsCount Int @default(0)

  // Relacionamentos
  ownerId     String
  owner       User      @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String?

  @@index([status])
  @@index([propertyType])
  @@index([transactionType])
  @@index([price])
  @@index([ownerId])
  @@index([createdAt])
  @@index([publishedAt])
}
